{
    "name": "turso/libsql-laravel",
    "type": "library",
    "autoload": {
        "psr-4": {
            "Libsql\\Laravel\\": "src/",
            "Libsql\\Laravel\\Tests\\": "tests/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "require": {
        "turso/libsql": "^0.2.5",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "spatie/laravel-package-tools": "^1.16",
        "cweagans/composer-patches": "^1.7"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.64",
        "phpstan/phpstan": "^2.1",
        "pestphp/pest": "^3.7",
        "orchestra/testbench": "^9.9||^10.0||^11.0"
    },
    "authors": [
        {
            "name": "Levy A.",
            "email": "levyddsa@gmail.com"
        }
    ],
    "scripts": {
        "test": [
            "@php vendor/bin/pest"
        ],
        "test-feature": [
            "@php vendor/bin/pest --testsuite=Feature"
        ],
        "test-unit": [
            "@php vendor/bin/pest --testsuite=Unit"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Libsql\\Laravel\\LibsqlServiceProvider"
            ]
        },
        "composer-exit-on-patch-failure": true,
        "patches": {
            "turso/libsql": {
                "Fix CharBox crash on empty strings (zero-length pointer)": "https://raw.githubusercontent.com/Ben52/libsql-laravel/main/patches/libsql-charbox-empty.patch"
            }
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "cweagans/composer-patches": true
        },
        "audit": {
            "block-insecure": false
        }
    }
}
